            "index": 0
          }
        ],
        [
          {
            "node": "Done",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Send Email (SMTP)": {
      "main": [
        [
          {
            "node": "Mark Success",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Mark Success": {
      "main": [
        [
          {
            "node": "Callback to Supabase",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Mark Failed": {
      "main": [
        [
          {
            "node": "Callback to Supabase",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Callback to Supabase": {
      "main": [
        [
          {
            "node": "Wait 1.5s Between Batches",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Wait 1.5s Between Batches": {
      "main": [
        [
          {
            "node": "Rate Limiter (5 per batch)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner",
    "errorWorkflow": ""
  },
  "staticData": null,
  "tags": [
    {
      "name": "email-campaigns",
      "id": "email-campaigns"
    }
  ],
  "triggerCount": 1,
